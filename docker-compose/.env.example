# looky — Docker Compose production deployment
# Copy to .env and fill in values
#
# Usage: docker compose --env-file .env -f docker-compose.yml up -d

# --- Required (paths relative to compose file location) ---
IMAGE_TAG=20260317.1
STATIC_ASSET_VERSION=20260317.1
POSTGRES_DATA_PATH=../data/postgres
WORKSPACES_PATH=../workspaces

# --- LOOKY_DB (Postgres: auth + workspace content) ---
LOOKY_DB_NAME=looky_ui
LOOKY_DB_USER=looky
LOOKY_DB_PASSWORD=looky
LOOKY_DB_URL=postgresql://looky:looky@postgres:5432/looky_ui

# --- Auth & Session ---
LOOKY_SESSION_SECRET=
EXPORT_ENGINE_SHARED_TOKEN=

# Invitation token encryption (Fernet). For production generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INVITATION_TOKEN_ENCRYPTION_KEY=

# --- Stytch (auth, email OTP, required) ---
STYTCH_PROJECT_ID=
STYTCH_SECRET=
STYTCH_ENV=test
STYTCH_PROJECT_TYPE=b2b
STYTCH_ORGANIZATION_ID=

# --- Optional ---
COMPOSE_PROJECT_NAME=looky
DEFAULT_WORKSPACE_ID=paranoid-software/default
WORKSPACE_CONTENT_WATCHER_DEBOUNCE_MS=500

# --- Port overrides (defaults: 8000, 55432, 3002, 6379) ---
# BACKEND_HOST_PORT=8000
# LOOKY_DB_HOST_PORT=55432
# MALLOY_SERVICE_HOST_PORT=3002
# REDIS_HOST_PORT=6379
