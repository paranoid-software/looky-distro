# looky — Docker Compose production deployment
# Copy to .env and fill in values
#
# Usage: docker compose --env-file .env -f docker-compose.yml up -d

# --- Required (paths relative to compose file location) ---
IMAGE_TAG=
STATIC_ASSET_VERSION=
POSTGRES_DATA_PATH=
WORKSPACES_PATH=

# --- LOOKY_DB (Postgres: auth + workspace content) ---
LOOKY_DB_NAME=looky
LOOKY_DB_USER=looky
LOOKY_DB_PASSWORD=looky
LOOKY_DB_URL=postgresql://looky:looky@postgres:5432/looky

# --- Auth & Session ---
LOOKY_SESSION_SECRET=
EXPORT_ENGINE_SHARED_TOKEN=

# Invitation token encryption (Fernet). For production generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INVITATION_TOKEN_ENCRYPTION_KEY=

# --- Stytch (auth, email OTP, required) ---
STYTCH_PROJECT_ID=
STYTCH_SECRET=
STYTCH_ENV=test
STYTCH_PROJECT_TYPE=b2b
STYTCH_ORGANIZATION_ID=

# --- Optional ---
COMPOSE_PROJECT_NAME=looky
DEFAULT_WORKSPACE_ID=
WORKSPACE_CONTENT_WATCHER_DEBOUNCE_MS=500

# --- Default KV (Redis-backed; queues, caches, status keys) ---
# Authoritative defaults live in ``looky/app/src/settings.py`` and
# ``looky/export-engine/export_engine/config.py``. Compose passes
# the var through unchanged. Set here ONLY to override.
# DEFAULT_KV_URL=redis://redis:6379/0

# --- Messaging (RabbitMQ) ---
# Empty by default — messaging is OFF in prod until you point it at
# a broker. When you wire one up, set DEFAULT_MESSAGING_URL and the
# corresponding rabbitmq network in the compose file. The bq-stats
# telemetry publisher only emits when both vars are set.
# DEFAULT_MESSAGING_URL=amqp://looky:<password>@rabbitmq:5672/looky
# BQ_JOBS_STATS_EXCHANGE=bq-jobs-stats

# --- Structured logging ---
# Floor for the JSON log formatter installed by ``setup_logging`` in
# every component (see SPEC_CENTRALIZED_LOGGING.md). Default INFO.
# DEBUG is noisy — useful when chasing a specific incident, expensive
# at steady state.
LOG_LEVEL=INFO

# --- Async validation queue (server-side `looky validate` / `looky push`) ---
# Defaults are sensible; override only if you have a reason.
# VALIDATION_JOB_TTL_MINUTES=30        # how long a job's state lives in Redis
# VALIDATION_JOB_MAX_WORKERS=4         # threads in the dispatcher pool
# VALIDATION_MAX_CONCURRENCY=4         # parallel compile/dry-run per job
# VALIDATION_STAGING_TTL_MINUTES=30    # janitor sweep age for abandoned staging dirs

# --- Port overrides (defaults: 8000, 55432, 3002, 6379) ---
# BACKEND_HOST_PORT=8000
# LOOKY_DB_HOST_PORT=55432
# MALLOY_SERVICE_HOST_PORT=3002
# REDIS_HOST_PORT=6379
